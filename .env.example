# Fine-grained personal access token with repository Metadata: Read access.
GITHUB_TOKEN=github_pat_xxx

# Optional configuration
PORT=8666
CACHE_TTL_MINUTES=360
REFRESH_INTERVAL_MINUTES=360
GITHUB_API_VERSION=2026-03-10
# PUBLIC_BASE_URL=https://stars.example.com

# Required in production. Generate a unique random value of at least 32 characters.
EMBED_SIGNING_KEY=
EMBED_RATE_LIMIT_PER_MINUTE=120
API_RATE_LIMIT_PER_MINUTE=240

# Referer allowlist. This is the default; add your own trusted sites if needed.
EMBED_ALLOWED_HOSTS=github.com,*.githubusercontent.com,*.github.io

# Enable only when the app is behind a trusted reverse proxy.
TRUST_PROXY=false

# Keep false for a public deployment. Enabling exposes private repository metadata and charts.
INCLUDE_PRIVATE_REPOSITORIES=false
